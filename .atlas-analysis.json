  "keyFeatures": [
    "Self-hosted Tailscale control server with full protocol compatibility",
    "Node registration via web authentication, pre-auth keys, and OIDC",
    "Access control lists (ACLs) with HuJSON policy format",
    "Embedded DERP relay server for NAT traversal",
    "MagicDNS with split DNS and custom DNS records",
    "Subnet routers and exit nodes for network routing",
    "Tags-as-identity model for service account nodes",
    "REST API and gRPC interface for programmatic control",
    "SQLite and PostgreSQL database backends",
    "Dual-stack IPv4 and IPv6 support"
  ],
  "publicApiSurface": [
    "REST API: GET/POST /api/v1/user",
    "REST API: GET/POST /api/v1/node",
    "REST API: POST /api/v1/auth/register",
    "REST API: GET/POST /api/v1/preauthkey",
    "REST API: GET/POST /api/v1/policy",
    "gRPC: HeadscaleService (proto/headscale/v1/headscale.proto)",
    "CLI: headscale users create/list/delete",
    "CLI: headscale nodes list/register/delete/expire",
    "CLI: headscale preauthkeys create/list/expire",
    "CLI: headscale apikeys create/list/expire",
    "CLI: headscale policy get/set",
    "CLI: headscale routes list/enable/disable"
  ]
}
